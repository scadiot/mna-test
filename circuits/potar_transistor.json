{
  "name": "Potentiomètre pilotant un transistor NPN",
  "dt": 1e-4,
  "components": [
    {
      "id": "V_cc",
      "type": "voltage_source",
      "node_pos": "N_vcc",
      "node_neg": "GND",
      "params": { "waveform": "dc", "amplitude": 12.0 }
    },
    {
      "id": "POT1",
      "type": "potentiometer",
      "node_a": "N_vcc",
      "node_b": "GND",
      "node_wiper": "N_wiper",
      "params": { "resistance": 10000.0, "ratio": 0.5 }
    },
    {
      "id": "R_base",
      "type": "resistor",
      "node_a": "N_wiper",
      "node_b": "N_base",
      "params": { "resistance": 100000.0 }
    },
    {
      "id": "R_collector",
      "type": "resistor",
      "node_a": "N_vcc",
      "node_b": "N_collector",
      "params": { "resistance": 1000.0 }
    },
    {
      "id": "Q1",
      "type": "transistor_bjt",
      "node_base": "N_base",
      "node_collector": "N_collector",
      "node_emitter": "GND",
      "params": { "beta": 100, "vce_sat": 0.2, "vbe_threshold": 0.6 }
    },
    {
      "id": "VM_col",
      "type": "voltmeter",
      "node_a": "N_collector",
      "node_b": "GND",
      "params": { "history_size": 500 }
    }
  ]
}
