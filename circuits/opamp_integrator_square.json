{
  "name": "Intégrateur à AOp — entrée carrée → triangle (100Hz, RC=1ms)",
  "dt": 1e-5,
  "components": [
    {
      "id": "V1",
      "type": "voltage_source",
      "node_pos": "IN",
      "node_neg": "GND",
      "params": { "waveform": "square", "amplitude": 1.0, "frequency": 100.0, "duty_cycle": 0.5 }
    },
    {
      "id": "VBIAS",
      "type": "voltage_source",
      "node_pos": "BIAS",
      "node_neg": "GND",
      "params": { "waveform": "dc", "amplitude": 0.5 }
    },
    {
      "id": "R1",
      "type": "resistor",
      "node_a": "IN",
      "node_b": "INV",
      "params": { "resistance": 10000.0 }
    },
    {
      "id": "C1",
      "type": "capacitor",
      "node_a": "INV",
      "node_b": "OUT",
      "params": { "capacitance": 1e-7 }
    },
    {
      "id": "OA1",
      "type": "opamp",
      "node_plus": "BIAS",
      "node_minus": "INV",
      "node_out": "OUT"
    },
    {
      "id": "VM_in",
      "type": "voltmeter",
      "node_a": "IN",
      "node_b": "GND",
      "params": { "history_size": 3000 }
    },
    {
      "id": "VM_out",
      "type": "voltmeter",
      "node_a": "OUT",
      "node_b": "GND",
      "params": { "history_size": 3000 }
    }
  ]
}
