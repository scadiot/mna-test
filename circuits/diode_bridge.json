    {
      "id": "D2",
      "type": "diode",
      "node_anode": "N2",
      "node_cathode": "N_out",
      "params": { "vf": 0.6 }
    },
    {
      "id": "D3",
      "type": "diode",
      "node_anode": "GND",
      "node_cathode": "N2",
      "params": { "vf": 0.6 }
    },
    {
      "id": "D4",
      "type": "diode",
      "node_anode": "GND",
      "node_cathode": "N1",
      "params": { "vf": 0.6 }
